{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingkong.app/schemas/session-state.schema.json",
  "title": "SessionState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "conversation_topic",
    "already_explained",
    "avoid_repetition",
    "max_length_chars"
  ],
  "properties": {
    "conversation_topic": {
      "type": "string",
      "enum": [
        "personality",
        "relationships",
        "career",
        "money",
        "family",
        "growth",
        "timing",
        "emotion",
        "decision",
        "general"
      ]
    },
    "turn_index": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 9999
    },
    "already_explained": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 220
      }
    },
    "avoid_repetition": {
      "type": "boolean"
    },
    "max_length_chars": {
      "type": "integer",
      "minimum": 60,
      "maximum": 2000
    },
    "recent_user_messages": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "last_answer_summary": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 300
    },
    "resolved_points": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 120
      }
    },
    "open_questions": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string",
        "maxLength": 120
      }
    },
    "should_ask_followup": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "forbidden_phrases": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "maxLength": 60
      }
    },
    "response_memory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "used_insights": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "used_tags": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "last_confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
