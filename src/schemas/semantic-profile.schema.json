{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingkong.app/schemas/semantic-profile.schema.json",
  "title": "SemanticProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "semantic_version",
    "top_tags",
    "top_insights"
  ],
  "properties": {
    "semantic_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "source_versions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engine_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "rule_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "ref_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "insight_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        }
      }
    },
    "top_tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/SemanticTagRef"
      }
    },
    "top_insights": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "$ref": "#/$defs/InsightRef"
      }
    },
    "guardrails": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/GuardrailRef"
      }
    },
    "confidence_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "tags": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "insights": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  },
  "$defs": {
    "SemanticTagRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tag_code",
        "category",
        "weight",
        "confidence"
      ],
      "properties": {
        "tag_code": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 1,
          "maxLength": 80
        },
        "category": {
          "type": "string",
          "enum": [
            "identity",
            "emotion",
            "mind",
            "relationship",
            "career",
            "money",
            "creativity",
            "family",
            "social",
            "growth",
            "timing",
            "shadow",
            "other"
          ]
        },
        "polarity": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "supportive",
            "challenging",
            "mixed",
            "neutral",
            null
          ]
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_refs": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "qualifiers": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "string",
            "maxLength": 80
          }
        }
      }
    },
    "InsightRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "insight_code",
        "category",
        "section",
        "confidence",
        "evidence_refs"
      ],
      "properties": {
        "insight_code": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 1,
          "maxLength": 100
        },
        "category": {
          "type": "string",
          "enum": [
            "strength",
            "tension",
            "theme",
            "opportunity",
            "risk",
            "growth"
          ]
        },
        "section": {
          "type": "string",
          "enum": [
            "summary",
            "personality",
            "relationships",
            "career",
            "money",
            "family",
            "growth",
            "timing",
            "shadow",
            "faq"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "priority": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 10
        },
        "tag_refs": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "summary_hint": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 180
        }
      }
    },
    "GuardrailRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$",
          "minLength": 1,
          "maxLength": 80
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "critical"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 220
        },
        "affected_scopes": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": [
              "houses",
              "angles",
              "timing",
              "relationships",
              "career",
              "money",
              "family",
              "overall"
            ]
          }
        }
      }
    }
  }
}
